EFG 2 R "Myerson (1991) Fig 4.2" { "Player 1" "Player 2" }
"An example from Myerson (1991) Fig 4.2 which has an agent Nash equilibrium that is
not a Nash equilibrium"

p "" 1 1 "" { "A1" "B1" } 0
p "" 2 1 "" { "W2" "X2" } 0
p "" 1 2 "" { "Y1" "Z1" } 0
t "" 1 "_1" { 3, 0 }
t "" 2 "_2" { 0, 0 }
p "" 1 2 "" { "Y1" "Z1" } 0
t "" 3 "_3" { 2, 3 }
t "" 4 "_4" { 4, 1 }
p "" 2 1 "" { "W2" "X2" } 0
t "" 5 "_5" { 2, 3 }
t "" 6 "_6" { 3, 2 }
